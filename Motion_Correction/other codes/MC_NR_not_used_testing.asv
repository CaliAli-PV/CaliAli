function out=MC_NR_not_used_testing(in,Vf,win,opt)
% out=MC_NR_not_used_testing(V);
if ~exist('win', 'var')
    win = min(opt.sf*6, size(in, 3));
elseif isempty(win)
    win = min(opt.sf*6, size(in, 3));
end
%% Get Vesselness-filtered image
% VF=in2VF(in);
[X]=get_BS_neuron_enhance(in,Vf,opt);
%% Calculatign Shifts
out=get_alignments(X+1,in,win);
out=cat(3,out{:});
M=max(isnan(out),[],3);

if isa(in,'uint16')
    out=v2uint16(out);
elseif isa(in,'uint8')
    out=v2uint8(out);
end

out=out+1;

[d1,d2,d3]=size(out);
out=reshape(out,d1*d2,d3)+1;

M=M(:);

out(M,:)=0;
out=reshape(out,d1,d2,d3);

%  implay(cat(1,in,out));
end


function Vout2=get_alignments(X,in,win)

%% distribute video in 20-frames batches
disp('Distributing video in small batches...')
x=round(linspace(1,size(X,4),size(X,4)/win));
x(1)=0;
if length(x)==1
    x=[0,size(X,4)];
end
ms=get_score(X);
for i=1:size(x,2)-1
    MS{i}=ms(x(i)+1:x(i+1));
    G{i}=X(:,:,:,x(i)+1:x(i+1));
    V{i}=in(:,:,x(i)+1:x(i+1));
end

plotme=0;
opt{1,1}  = struct('stop_criterium',0.001,'imagepad',1.2,'niter',40, 'sigma_fluid',1,...
    'sigma_diffusion',6, 'sigma_i',1,...
    'sigma_x',1, 'do_display',plotme, 'do_plotenergy',plotme);
opt{2,1} = struct('stop_criterium',0.001,'imagepad',1.2,'niter',40, 'sigma_fluid',1,...
    'sigma_diffusion',6, 'sigma_i',1,...
    'sigma_x',1, 'do_display',plotme, 'do_plotenergy',plotme);
opt{3,1} = struct('stop_criterium',0.001,'imagepad',1.2,'niter',25, 'sigma_fluid',1,...
    'sigma_diffusion',3, 'sigma_i',1,...
    'sigma_x',1, 'do_display',plotme, 'do_plotenergy',plotme);

T=G{25}(:,:,:,10);
%%================================ Intra-batch registration
parfor k=1:size(x,2)-1
    [O{k},D{k},Va{k}]=batch_register(G{k},V{k},opt)
end

%%================================ Inter-batch registration
for i=1:size(G,2)
    a=uint8(mean(Va{i},3));
    b=uint8(max(squeeze(O{i}(:,:,1,:)),[],3));
    c=uint8(mean(squeeze(O{i}(:,:,3,:)),3));
    P(:,:,:,i)=cat(3,a,b,c);
end

[Vout,Po]=align_inter_sessions(P,Va);

a=max(squeeze(Po(:,:,2,:)),[],3);
b=mean(squeeze(Po(:,:,3,:)),3);


T=permute(cat(4,a,a,b),[1,2,4,3]);
%% Round 2
parfor k=1:size(x,2)-1
    [O2{k},D2{k},Vout2{k}]=batch_register(G{k},V{k},opt,T)
end



end

function [O,D,Vo]=batch_register(in,V,opt,ref)


if ~exist('ref','var')
    mid=round(size(in,3)/2);
    T=in(:,:,:,mid);
else
    T=ref;
end


D=zeros(size(T,1),size(T,2),2,size(in,4));

for i=1:size(in,4)
    [~,O(:,:,:,i),D(:,:,:,i)] =MR_Log_demon(T,in(:,:,:,i),opt);
    Vo(:,:,i) = imsharpen(imwarp(single(V(:,:,i)),D(:,:,:,i),"FillValues",nan));
    % T=O(:,:,:,i);
end

end

function t=get_score(V)
opt = struct('stop_criterium',0.001,'imagepad',1.2,'niter',5, 'sigma_fluid',1,...
    'sigma_diffusion',5, 'sigma_i',1,...
    'sigma_x',2, 'do_display',0, 'do_plotenergy',0);

[d1,d2,d3,d4]=size(V);
C=squeeze(mat2cell(V,d1,d2,d3,ones(1,d4)));
C(2:end,2)=C(1:end-1,1);
parfor i=2:d4
    K=C(i,:);
    im1=uint8(mean(K{1,2},3));
    im2=uint8(mean(K{1,1},3));
    [X1,X2,D]=MR_Log_demon(im1,im2,opt);
    %     sz=1;
    %     [~,temp]=ssim(im1,im2,'Exponents',[0 0 1],'Radius',sz,'RegularizationConstants',[0,0,0]);
    ou(:,:,i)=sqrt(D(:,:,1).^2+D(:,:,2).^2);
    %    ou(:,:,i-1)=1-imgaussfilt(temp,3);
end
t=squeeze(max(max(ou)));
t(1)=t(2);
end